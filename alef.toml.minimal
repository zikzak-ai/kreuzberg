languages = ["python", "node", "ruby", "php", "ffi", "go", "java", "csharp", "elixir", "wasm", "r"]

# ---------------------------------------------------------------------------
# Crate configuration
# ---------------------------------------------------------------------------

[crate]
name = "kreuzberg"
core_import = "kreuzberg"
version_from = "Cargo.toml"
workspace_root = "."
sources = [
    # Public re-exports and top-level functions
    "crates/kreuzberg/src/lib.rs",
    # Error type
    "crates/kreuzberg/src/error.rs",
    # Core types
    "crates/kreuzberg/src/types/extraction.rs",
    "crates/kreuzberg/src/types/metadata.rs",
    "crates/kreuzberg/src/types/page.rs",
    "crates/kreuzberg/src/types/tables.rs",
    "crates/kreuzberg/src/types/annotations.rs",
    "crates/kreuzberg/src/types/document_structure.rs",
    "crates/kreuzberg/src/types/ocr_elements.rs",
    "crates/kreuzberg/src/types/formats.rs",
    "crates/kreuzberg/src/types/uri.rs",
    "crates/kreuzberg/src/types/djot.rs",
    # Config types
    "crates/kreuzberg/src/core/config/mod.rs",
    "crates/kreuzberg/src/core/config/extraction/types.rs",
    "crates/kreuzberg/src/core/config/extraction/core.rs",
    "crates/kreuzberg/src/core/config/extraction/file_config.rs",
    "crates/kreuzberg/src/core/config/ocr.rs",
    "crates/kreuzberg/src/core/config/page.rs",
    "crates/kreuzberg/src/core/config/pdf.rs",
    "crates/kreuzberg/src/core/config/html_output.rs",
    "crates/kreuzberg/src/core/config/layout.rs",
    "crates/kreuzberg/src/core/config/acceleration.rs",
    "crates/kreuzberg/src/core/config/llm.rs",
    "crates/kreuzberg/src/core/config/content_filter.rs",
    "crates/kreuzberg/src/core/config/tree_sitter.rs",
    "crates/kreuzberg/src/core/config/email.rs",
    "crates/kreuzberg/src/core/config/formats.rs",
    # MIME detection and formats
    "crates/kreuzberg/src/core/mime.rs",
    "crates/kreuzberg/src/core/formats.rs",
    # Extraction functions
    "crates/kreuzberg/src/extraction/mod.rs",
    # Plugin system
    "crates/kreuzberg/src/plugins/traits.rs",
    "crates/kreuzberg/src/plugins/registry/mod.rs",
    # Cache
    "crates/kreuzberg/src/cache/mod.rs",
    "crates/kreuzberg/src/cache/core.rs",
    # Rendering
    "crates/kreuzberg/src/rendering/mod.rs",
    # Keywords
    "crates/kreuzberg/src/keywords/mod.rs",
    # Chunking
    "crates/kreuzberg/src/chunking/mod.rs",
    # Embeddings
    "crates/kreuzberg/src/embeddings/mod.rs",
    # Language detection
    "crates/kreuzberg/src/language_detection/mod.rs",
    # Image processing
    "crates/kreuzberg/src/image/mod.rs",
    # Layout detection
    "crates/kreuzberg/src/layout/mod.rs",
    # OCR types
    "crates/kreuzberg/src/ocr/types.rs",
    # PaddleOCR
    "crates/kreuzberg/src/paddle_ocr/mod.rs",
    # Document orientation
    "crates/kreuzberg/src/doc_orientation.rs",
    # Stopwords
    "crates/kreuzberg/src/stopwords/mod.rs",
    # Table core
    "crates/kreuzberg/src/table_core.rs",
]
features = [
    "full",
    "pdf",
    "ocr",
    "paddle-ocr",
    "layout-detection",
    "embeddings",
    "chunking",
    "keywords-yake",
    "keywords-rake",
    "language-detection",
    "html",
    "tree-sitter",
    "office",
    "email",
    "archives",
    "stopwords",
    "auto-rotate",
    "tokio-runtime",
    "api",
    "mcp",
    "liter-llm",
]

# ---------------------------------------------------------------------------
# Include / Exclude filters
# ---------------------------------------------------------------------------

[include]
types = [
    # Error
    "KreuzbergError",
    # Minimal safe types — only types with simple fields (String, bool, f64, u64, i64)
    "SupportedFormat",
    "LlmUsage",
]
functions = [
    # MIME detection — these return simple types (String, Vec<String>, Vec<SupportedFormat>)
    "detect_mime_type",
    "detect_mime_type_from_bytes",
    "validate_mime_type",
    "get_extensions_for_mime",
    "list_supported_formats",
    # Format utilities
    "is_valid_format_field",
]

[exclude]
types = [
    # =========================================================================
    # Types excluded due to alef codegen issues (From impls, tuple variants,
    # missing serde/Debug, integer width mismatches, etc.)
    # =========================================================================

    # FormatMetadata — tuple variant codegen bug (E0559/E0769)
    "FormatMetadata",
    "TextMetadata",
    "HtmlMetadata",
    "EmailMetadata",
    "EmailAttachment",
    "PdfAnnotation",
    "PdfAnnotationType",
    "HeaderMetadata",
    "LinkMetadata",
    "LinkType",
    "ImageMetadata",
    "ImageMetadataType",
    "ExcelMetadata",
    "ExcelSheet",
    "ExcelWorkbook",
    "CsvMetadata",
    "XmlMetadata",
    "DocxMetadata",
    "PptxMetadata",
    "EpubMetadata",
    "BibtexMetadata",
    "CitationMetadata",
    "JatsMetadata",
    "FictionBookMetadata",
    "ArchiveMetadata",
    "ArchiveEntry",
    "PstMetadata",
    "DbfMetadata",
    "DbfFieldInfo",
    "ErrorMetadata",

    # NodeId — newtype missing serde, Debug, From impls
    "NodeId",
    "NodeIndex",

    # Document structure — depends on NodeId
    "DocumentStructure",
    "DocumentNode",
    "NodeContent",
    "TableGrid",
    "GridCell",
    "TextAnnotation",
    "AnnotationKind",
    "ContentLayer",
    "DocumentRelationship",
    "RelationshipKind",
    "Footnote",

    # OCR types — missing From impls, integer width issues
    "OcrPipelineConfig",
    "OcrPipelineStage",
    "OcrQualityThresholds",
    "OcrElementConfig",
    "TesseractConfig",
    "PSMMode",
    "ImagePreprocessingConfig",
    "ImagePreprocessingMetadata",
    "OcrExtractionResult",
    "OcrMetadata",
    "OcrElement",
    "OcrElementLevel",
    "OcrBoundingGeometry",
    "OcrConfidence",
    "OcrRotation",
    "OcrTable",
    "OcrTableBoundingBox",

    # OcrConfig — depends on OcrPipelineConfig
    "OcrConfig",

    # ExtractionConfig — depends on OcrConfig, FormatMetadata via Metadata
    "ExtractionConfig",
    "FileExtractionConfig",
    "ImageExtractionConfig",

    # ExtractionResult — depends on Metadata (which has FormatMetadata)
    "ExtractionResult",
    "Metadata",
    "PageContent",
    "Table",
    "TableCell",

    # Config types that depend on excluded types
    "PostProcessorConfig",
    "HierarchyConfig",
    "ContentFilterConfig",
    "TokenReductionConfig",
    "StructuredExtractionConfig",
    "LlmConfig",
    "LayoutDetectionConfig",
    "TableModel",
    "AccelerationConfig",
    "ExecutionProviderType",

    # Layout types — reference/conversion issues
    "LayoutDetection",
    "DetectionResult",
    "LayoutClass",
    "BBox",

    # Embedding types — missing Default/From
    "EmbeddingConfig",
    "EmbeddingModelType",

    # Chunk types — usize fields cause integer width issues
    "Chunk",
    "ChunkMetadata",
    "ChunkType",
    "ChunkingConfig",
    "ChunkerType",
    "ChunkSizing",
    "HeadingContext",
    "HeadingLevel",

    # Processing warning — Cow<'static, str> may be problematic
    "ProcessingWarning",

    # Other types with codegen issues
    "OutputFormat",
    "PdfConfig",
    "PdfBackend",
    "PageConfig",
    "EmailConfig",
    "LanguageDetectionConfig",
    "HtmlOutputConfig",
    "HtmlTheme",
    "TreeSitterConfig",
    "TreeSitterProcessConfig",
    "CodeContentMode",
    "OrientationResult",
    "TextExtractionResult",
    "XmlExtractionResult",
    "EmailExtractionResult",
    "PptxExtractionResult",
    "OcrBackendType",
    "ProcessingStage",
    "PaddleOcrConfig",
    "PaddleLanguage",
    "ModelPaths",
    "Keyword",
    "KeywordConfig",
    "KeywordAlgorithm",
    "RakeParams",
    "YakeParams",
    "Uri",
    "UriKind",
    "DjotContent",
    "DjotImage",
    "DjotLink",
    "StructuredData",
    "StructuredDataType",
    "PageBoundary",
    "PageHierarchy",
    "PageInfo",
    "PageStructure",
    "PageUnitType",
    "BoundingBox",

    # =========================================================================
    # Internal types — not part of public API
    # =========================================================================
    "DocumentStructureBuilder",
    "InternalDocument",
    "InternalDocumentBuilder",
    "InternalElement",
    "InternalElementId",
    "ModelManifestEntry",
    "RecModelPaths",
    "ResolvedRecModel",
    "SharedModelPaths",
    "LayoutEngine",
    "LayoutEngineConfig",
    "LayoutModelManager",
    "LayoutError",
    "RtDetrModel",
    "SlanetModel",
    "SlanetResult",
    "SlanetCell",
    "CellBBox",
    "TatrModel",
    "TatrResult",
    "TatrDetection",
    "TatrClass",
    "YoloModel",
    "YoloVariant",
    "CustomModelVariant",
    "ModelBackend",
    "TableClassifier",
    "TableType",
    "DetectTimings",
    "BatchItemResult",
    "NormalizeResult",
    "EmbeddingEngine",
    "EmbedError",
    "Pooling",
    "LanguageDetector",
    "KeywordExtractor",
    "DocOrientationDetector",
    "ConcurrencyConfig",
    "JsonDocument",
    "JsonNode",
    "PaddleOcrBackend",
    "ModelManager",
    "SecurityLimits",
    "PluginHealthStatus",
    "Run",
    "Paragraph",
    "DocxAppProperties",
    "CoreProperties",
    "CellBorders",
    "CellMargins",
    "CellProperties",
    "CellShading",
    "BorderStyle",
    "TableWidth",
    "VerticalMerge",
    "Relationship",
    "RelationshipTarget",
    "ElementKind",
    "ParagraphProperties",
    "ParagraphMeta",
    "StyledHtmlRenderer",
    "EmbeddingPreset",
    "CacheStats",
    "ImageDpiConfig",

    # WASM JS-specific wrapper types
    "JsEmbeddingConfig",
    "JsImagePreprocessingMetadata",
    "JsLanguageDetectionConfig",
    "JsLayoutDetectionConfig",
    "JsLlmConfig",
    "JsOcrElementConfig",
    "JsOcrPipelineConfig",
    "JsOcrQualityThresholds",
    "JsTesseractConfig",
    "JsCoreProperties",
    "JsDocxAppProperties",
    "JsExtractionResult",
    "JsKeywordConfig",
    "JsNodeId",
    "JsOutputFormat",
    "JsTableGrid",
    "JsExtractionConfig",
]
functions = [
    # Excluded: reference excluded types
    "extract_file",
    "extract_bytes",
    "extract_file_sync",
    "extract_bytes_sync",
    "batch_extract_file",
    "batch_extract_bytes",
    "batch_extract_file_sync",
    "batch_extract_bytes_sync",
    "serialize_to_toon",
    "serialize_to_json",
    "embed_texts",
    "embed_texts_async",
    "download_model",
    "warm_model",
    "list_presets",
    "get_preset",
    "extract_keywords",
    "get_stopwords",
    "get_stopwords_with_fallback",
    "get_document_extractor_registry",
    "get_ocr_backend_registry",
    "get_post_processor_registry",
    "get_renderer_registry",
    "get_validator_registry",
    # Path-based functions with Option<&Path> signature that alef can't handle
    "detect_or_validate",
    # Internal functions
    "resolve_cache_dir",
    "detect_and_rotate",
    "ensure_initialized",
    "register_keyword_processor",
    "register_chunking_processor",
]
methods = []

# ---------------------------------------------------------------------------
# Output directories
# ---------------------------------------------------------------------------

[output]
python = "crates/kreuzberg-py/src/"
node = "crates/kreuzberg-node/src/"
ruby = "packages/ruby/ext/kreuzberg_rb/src/"
php = "crates/kreuzberg-php/src/"
ffi = "crates/kreuzberg-ffi/src/"
go = "packages/go/"
elixir = "packages/elixir/native/kreuzberg_nif/src/"
wasm = "crates/kreuzberg-wasm/src/"
java = "packages/java/src/main/java/dev/kreuzberg/"
csharp = "packages/csharp/src/"
r = "packages/r/src/rust/src/"

# ---------------------------------------------------------------------------
# Language-specific configuration
# ---------------------------------------------------------------------------

[python]
module_name = "_kreuzberg"

[python.stubs]
output = "packages/python/kreuzberg/"

[node]
package_name = "kreuzberg"

[ffi]
prefix = "kreuzberg"
header_name = "kreuzberg.h"
lib_name = "kreuzberg_ffi"
visitor_callbacks = false

[go]
module = "github.com/kreuzberg-dev/kreuzberg/v4"
package_name = "kreuzberg"

[java]
package = "dev.kreuzberg"
ffi_style = "panama"

[csharp]
namespace = "Kreuzberg"

[ruby]
gem_name = "kreuzberg"

[elixir]
app_name = "kreuzberg"

[php]
extension_name = "kreuzberg"

[r]
package_name = "kreuzberg"

[wasm]
# All complex types already excluded globally; only WASM-specific overrides here
exclude_types = []
exclude_functions = []
features = ["html"]

# ---------------------------------------------------------------------------
# DTO styles
# ---------------------------------------------------------------------------

[dto]
python = "dataclass"
python_output = "typed-dict"
node = "interface"
ruby = "struct"
php = "readonly-class"
elixir = "struct"
go = "struct"
java = "record"
csharp = "record"
r = "list"

# ---------------------------------------------------------------------------
# Scaffold metadata
# ---------------------------------------------------------------------------

[scaffold]
description = "High-performance document intelligence library"
license = "Elastic-2.0"
repository = "https://github.com/kreuzberg-dev/kreuzberg"
homepage = "https://kreuzberg.dev"
authors = ["Na'aman Hirschfeld <naaman@kreuzberg.dev>"]
keywords = ["document", "extraction", "pdf", "ocr", "text"]

# ---------------------------------------------------------------------------
# Generation control
# ---------------------------------------------------------------------------

[generate]
bindings = true
errors = true
configs = true
async_wrappers = true
type_conversions = true
package_metadata = true
public_api = true

[generate_overrides.wasm]
async_wrappers = false

# ---------------------------------------------------------------------------
# Version synchronization
# ---------------------------------------------------------------------------

[sync]
extra_paths = [
    "packages/python/kreuzberg/__init__.py",
    "packages/ruby/lib/kreuzberg/version.rb",
    "crates/kreuzberg-node/package.json",
    "crates/kreuzberg-node/npm/*/package.json",
    "packages/go/go.mod",
]

# ---------------------------------------------------------------------------
# Adapters — all currently excluded (reference excluded types)
# ---------------------------------------------------------------------------
# Adapters will be re-added as types are brought back into include list.

# ---------------------------------------------------------------------------
# Test commands
# ---------------------------------------------------------------------------

[test.python]
command = "task python:test"
e2e = "cd e2e/python && python3 -m pytest tests/ -q"

[test.node]
command = "npx vitest run --config packages/typescript/vitest.config.ts"
e2e = "cd e2e/typescript && npx vitest run"

[test.go]
command = "task go:test"
e2e = "cd e2e/go && go test ./... -count=1"

[test.ruby]
command = "task ruby:test"

[test.php]
command = "task php:test"

[test.java]
command = "task java:test"

[test.csharp]
command = "task csharp:test"

[test.elixir]
command = "task elixir:test"
e2e = "cd e2e/elixir && mix test"

[test.r]
command = "task r:test"
e2e = "cd e2e/r && Rscript -e \"devtools::load_all('../../packages/r'); testthat::set_max_fails(Inf); testthat::test_dir('tests')\""

[test.wasm]
e2e = "cd e2e/wasm && npm test"

[test.rust]
e2e = "cd e2e/rust && cargo test"

# ---------------------------------------------------------------------------
# Lint commands
# ---------------------------------------------------------------------------

[lint.python]
format = "ruff format packages/python/"
check = "ruff check packages/python/"
typecheck = "mypy packages/python/"

[lint.node]
format = "npx biome format --write packages/typescript/"
check = "npx biome check packages/typescript/"

[lint.ruby]
format = "bundle exec rubocop -a packages/ruby/"
check = "bundle exec rubocop packages/ruby/"

[lint.php]
format = "phpcbf packages/php/"
check = "phpstan analyse packages/php/"

[lint.go]
check = "cd packages/go && golangci-lint run"

# ---------------------------------------------------------------------------
# E2E test generation
# ---------------------------------------------------------------------------

[e2e]
fixtures = "fixtures"
output = "e2e"
languages = ["python", "rust", "node", "go", "ruby", "elixir", "wasm"]
fields_optional = ["content", "metadata.format"]

[e2e.call]
function = "extract_file"
module = "kreuzberg"
result_var = "result"
async = true
args = [
    { name = "path", field = "input.path", type = "string" },
    { name = "mime_type", field = "input.mime_type", type = "string", optional = true },
    { name = "config", field = "input.config", type = "json_object", optional = true },
]

[e2e.call.overrides.rust]
crate_name = "kreuzberg"
function = "extract_file"

[e2e.call.overrides.python]
module = "kreuzberg"
function = "extract_file"
options_type = "ExtractionConfig"

[e2e.call.overrides.node]
module = "kreuzberg"
function = "extractFile"
options_type = "ExtractionConfig"

[e2e.call.overrides.go]
module = "github.com/kreuzberg-dev/kreuzberg/v4"
function = "ExtractFile"
alias = "kreuzberg"
options_type = "ExtractionConfig"

[e2e.call.overrides.java]
class = "dev.kreuzberg.Kreuzberg"
function = "extractFile"
options_type = "ExtractionConfig"

[e2e.call.overrides.csharp]
class = "Kreuzberg"
function = "ExtractFile"
options_type = "ExtractionConfig"

[e2e.call.overrides.ruby]
options_type = "Kreuzberg::ExtractionConfig"

[e2e.call.overrides.elixir]
options_type = "ExtractionConfig"
handle_struct_type = "ExtractionConfig"

[e2e.call.overrides.wasm]
options_type = "JsExtractionConfig"

# Named call configs for multi-function testing

[e2e.calls.extract_bytes]
function = "extract_bytes"
module = "kreuzberg"
async = true
args = [
    { name = "data", field = "input.data", type = "bytes" },
    { name = "mime_type", field = "input.mime_type", type = "string" },
    { name = "config", field = "input.config", type = "json_object", optional = true },
]

[e2e.calls.extract_file_sync]
function = "extract_file_sync"
module = "kreuzberg"
async = false
args = [
    { name = "path", field = "input.path", type = "string" },
    { name = "mime_type", field = "input.mime_type", type = "string", optional = true },
    { name = "config", field = "input.config", type = "json_object", optional = true },
]

[e2e.calls.extract_bytes_sync]
function = "extract_bytes_sync"
module = "kreuzberg"
async = false
args = [
    { name = "data", field = "input.data", type = "bytes" },
    { name = "mime_type", field = "input.mime_type", type = "string" },
    { name = "config", field = "input.config", type = "json_object", optional = true },
]

[e2e.calls.embed]
function = "embed_texts"
module = "kreuzberg"
async = false
args = [
    { name = "texts", field = "input.texts", type = "json_object" },
    { name = "config", field = "input.config", type = "json_object", optional = true },
]

[e2e.calls.render_page]
function = "render_page"
module = "kreuzberg"
async = false
args = [
    { name = "path", field = "input.path", type = "string" },
    { name = "page", field = "input.page", type = "int" },
    { name = "config", field = "input.config", type = "json_object", optional = true },
]

# Package references for e2e tests

[e2e.packages.rust]
path = "../../crates/kreuzberg"

[e2e.packages.python]
name = "kreuzberg"
path = "../../packages/python"

[e2e.packages.node]
name = "kreuzberg"
path = "../../crates/kreuzberg-node"

[e2e.packages.go]
module = "github.com/kreuzberg-dev/kreuzberg/v4"
path = "../../packages/go"
version = "v0.0.0"

[e2e.packages.csharp]
name = "Kreuzberg"
path = "../../packages/csharp/Kreuzberg/Kreuzberg.csproj"

[e2e.format]
python = "ruff check --fix {dir} && ruff format {dir}"
go = "gofmt -w {dir}"
rust = "cargo fmt --manifest-path {dir}/Cargo.toml"

[e2e.fields]
"metadata.title" = "metadata.format"

[e2e.fields_c_types]
"extraction_result.metadata" = "Metadata"

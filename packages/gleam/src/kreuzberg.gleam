    mime_type: String,
    metadata: Metadata,
    extraction_method: Option(ExtractionMethod),
    tables: List(Table),
    detected_languages: Option(List(String)),
    chunks: Option(List(Chunk)),
    images: Option(List(ExtractedImage)),
    pages: Option(List(PageContent)),
    elements: Option(List(Element)),
    djot_content: Option(DjotContent),
    ocr_elements: Option(List(OcrElement)),
    document: Option(DocumentStructure),
    extracted_keywords: Option(List(Keyword)),
    quality_score: Option(Float),
    processing_warnings: List(ProcessingWarning),
    annotations: Option(List(PdfAnnotation)),
    children: Option(List(ArchiveEntry)),
    uris: Option(List(Uri)),
    structured_output: Option(String),
    code_intelligence: Option(String),
    llm_usage: Option(List(LlmUsage)),
    formatted_content: Option(String),
    ocr_internal_document: Option(String)

pub type FormattedBlock {
  FormattedBlock(
    block_type: BlockType,
    level: Option(Int),
    inline_content: List(InlineElement),
    attributes: Option(String),
    language: Option(String),
    code: Option(String),
    children: List(FormattedBlock)
  )
}

/// Inline element within a block.
///

    attr_accessor algorithm: KeywordAlgorithm?
    attr_accessor max_keywords: Integer?
    attr_accessor min_score: Float?
    attr_accessor ngram_range: Array[Integer]?
    attr_accessor language: String?
    attr_accessor yake_params: YakeParams?
    attr_accessor rake_params: RakeParams?

    def initialize: (?algorithm: KeywordAlgorithm, ?max_keywords: Integer, ?min_score: Float, ?ngram_range: Array[Integer], ?language: String, ?yake_params: YakeParams, ?rake_params: RakeParams) -> void

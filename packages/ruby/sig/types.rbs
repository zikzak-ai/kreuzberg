    attr_reader data: String
    attr_reader format: String
    attr_reader image_index: Integer
    attr_reader page_number: Integer
    attr_reader width: Integer
    attr_reader height: Integer
    attr_reader colorspace: String
    attr_reader bits_per_component: Integer
    attr_reader is_mask: bool
    attr_reader description: String
    attr_reader ocr_result: ExtractionResult
    attr_reader bounding_box: String
    attr_reader source_path: String
    attr_reader image_kind: ImageKind
    attr_reader kind_confidence: Float
    attr_reader cluster_id: Integer

    def initialize: (data: String, format: String, image_index: Integer, ?page_number: Integer, ?width: Integer, ?height: Integer, ?colorspace: String, ?bits_per_component: Integer, is_mask: bool, ?description: String, ?ocr_result: ExtractionResult, ?bounding_box: String, ?source_path: String, ?image_kind: ImageKind, ?kind_confidence: Float, ?cluster_id: Integer) -> void
  end

  class ElementMetadata
    # Metadata for a semantic element.


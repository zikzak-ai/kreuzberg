    def initialize: (max_archive_size: Integer, max_compression_ratio: Integer, max_files_in_archive: Integer, max_nesting_depth: Integer, max_entity_length: Integer, max_content_size: Integer, max_iterations: Integer, max_xml_depth: Integer, max_table_cells: Integer) -> void
    def self.default: () -> SecurityLimits
  end

  class TokenReductionConfig
    attr_accessor level: ReductionLevel?
    attr_accessor language_hint: String?
    attr_accessor preserve_markdown: bool?
    attr_accessor preserve_code: bool?
    attr_accessor semantic_threshold: Float?
    attr_accessor enable_parallel: bool?
    attr_accessor use_simd: bool?
    attr_accessor custom_stopwords: Hash[String, Array[String]]?
    attr_accessor preserve_patterns: Array[String]?
    attr_accessor target_reduction: Float?
    attr_accessor enable_semantic_clustering: bool?

    def initialize: (level: ReductionLevel, ?language_hint: String, preserve_markdown: bool, preserve_code: bool, semantic_threshold: Float, enable_parallel: bool, use_simd: bool, ?custom_stopwords: Hash[String, Array[String]], preserve_patterns: Array[String], ?target_reduction: Float, enable_semantic_clustering: bool) -> void
    def self.default: () -> TokenReductionConfig
  end

  class PdfAnnotation
    # A PDF annotation extracted from a document page.

    attr_reader annotation_type: PdfAnnotationType
    attr_reader content: String
    attr_reader page_number: Integer
    attr_reader bounding_box: String

    def initialize: (annotation_type: PdfAnnotationType, ?content: String, page_number: Integer, ?bounding_box: String) -> void
  end

  class DjotContent
    # Comprehensive Djot document structure with semantic preservation.
    #
    # This type captures the full richness of Djot markup, including:
    # - Block-level structures (headings, lists, blockquotes, code blocks, etc.)
    # - Inline formatting (emphasis, strong, highlight, subscript, superscript, etc.)
    # - Attributes (classes, IDs, key-value pairs)
    # - Links, images, footnotes
    # - Math expressions (inline and display)
    # - Tables with full structure
    #
    # Available when the `djot` feature is enabled.

    attr_reader plain_text: String
    attr_reader blocks: Array[FormattedBlock]
    attr_reader metadata: Metadata
    attr_reader tables: Array[Table]
    attr_reader images: Array[DjotImage]
    attr_reader links: Array[DjotLink]
    attr_reader footnotes: Array[Footnote]
    attr_reader attributes: Array[String]

    def initialize: (plain_text: String, blocks: Array[FormattedBlock], metadata: Metadata, tables: Array[Table], images: Array[DjotImage], links: Array[DjotLink], footnotes: Array[Footnote], attributes: Array[String]) -> void
  end

  class FormattedBlock
    # Block-level element in a Djot document.
    #
    # Represents structural elements like headings, paragraphs, lists, code blocks, etc.

    attr_reader block_type: BlockType
    attr_reader level: Integer
    attr_reader inline_content: Array[InlineElement]
    attr_reader attributes: String
    attr_reader language: String
    attr_reader code: String
    attr_reader children: Array[FormattedBlock]

    def initialize: (block_type: BlockType, ?level: Integer, inline_content: Array[InlineElement], ?attributes: String, ?language: String, ?code: String, children: Array[FormattedBlock]) -> void
  end

  class InlineElement
    # Inline element within a block.
    #
    # Represents text with formatting, links, images, etc.

    attr_reader element_type: InlineType
    attr_reader content: String
    attr_reader attributes: String
    attr_reader metadata: Hash[String, String]

    def initialize: (element_type: InlineType, content: String, ?attributes: String, ?metadata: Hash[String, String]) -> void
  end

  class DjotImage
    # Image element in Djot.

    attr_reader src: String
    attr_reader alt: String
    attr_reader title: String
    attr_reader attributes: String

    def initialize: (src: String, alt: String, ?title: String, ?attributes: String) -> void
  end

  class DjotLink
    # Link element in Djot.

    attr_reader url: String
    attr_reader text: String
    attr_reader title: String
    attr_reader attributes: String

    def initialize: (url: String, text: String, ?title: String, ?attributes: String) -> void
  end

  class Footnote
    # Footnote in Djot.

    attr_reader label: String
    attr_reader content: Array[FormattedBlock]

    def initialize: (label: String, content: Array[FormattedBlock]) -> void
  end

  class DocumentStructure
    # Top-level structured document representation.
    #
    # A flat array of nodes with index-based parent/child references forming a tree.
    # Root-level nodes have `parent: None`. Use `body_roots()` and `furniture_roots()`
    # to iterate over top-level content by layer.
    #
    # # Validation
    #
    # Call `validate()` after construction to verify all node indices are in bounds
    # and parent-child relationships are bidirectionally consistent.

    attr_accessor nodes: Array[DocumentNode]?
    attr_accessor source_format: String?
    attr_accessor relationships: Array[DocumentRelationship]?
    attr_accessor node_types: Array[String]?

    def initialize: (nodes: Array[DocumentNode], ?source_format: String, relationships: Array[DocumentRelationship], node_types: Array[String]) -> void
    def finalize_node_types: () -> void
    def is_empty: () -> bool
    def self.default: () -> DocumentStructure
  end

  class DocumentRelationship
    # A resolved relationship between two nodes in the document tree.

    attr_reader source: Integer
    attr_reader target: Integer
    attr_reader kind: RelationshipKind

    def initialize: (source: Integer, target: Integer, kind: RelationshipKind) -> void
  end

  class DocumentNode
    # A single node in the document tree.
    #
    # Each node has deterministic `id`, typed `content`, optional `parent`/`children`
    # for tree structure, and metadata like page number, bounding box, and content layer.

    attr_reader id: String
    attr_reader content: NodeContent
    attr_reader parent: Integer
    attr_reader children: Array[Integer]
    attr_reader content_layer: ContentLayer
    attr_reader page: Integer
    attr_reader page_end: Integer
    attr_reader bbox: String
    attr_reader annotations: Array[TextAnnotation]
    attr_reader attributes: Hash[String, String]

    def initialize: (id: String, content: NodeContent, ?parent: Integer, children: Array[Integer], content_layer: ContentLayer, ?page: Integer, ?page_end: Integer, ?bbox: String, annotations: Array[TextAnnotation], ?attributes: Hash[String, String]) -> void
  end

  class TableGrid
    # Structured table grid with cell-level metadata.
    #
    # Stores row/column dimensions and a flat list of cells with position info.

    attr_accessor rows: Integer?
    attr_accessor cols: Integer?
    attr_accessor cells: Array[GridCell]?

    def initialize: (rows: Integer, cols: Integer, cells: Array[GridCell]) -> void
  end

  class GridCell
    # Individual grid cell with position and span metadata.

    attr_reader content: String
    attr_reader row: Integer
    attr_reader col: Integer
    attr_reader row_span: Integer
    attr_reader col_span: Integer
    attr_reader is_header: bool
    attr_reader bbox: String

    def initialize: (content: String, row: Integer, col: Integer, row_span: Integer, col_span: Integer, is_header: bool, ?bbox: String) -> void
  end

  class TextAnnotation
    # Inline text annotation — byte-range based formatting and links.
    #
    # Annotations reference byte offsets into the node's text content,
    # enabling precise identification of formatted regions.

    attr_reader start: Integer
    attr_reader end: Integer
    attr_reader kind: AnnotationKind

    def initialize: (start: Integer, end: Integer, kind: AnnotationKind) -> void
  end

  class ExtractionResult
    # General extraction result used by the core extraction API.
    #
    # This is the main result type returned by all extraction functions.

    attr_accessor content: String?
    attr_accessor mime_type: String?
    attr_accessor metadata: Metadata?
    attr_accessor extraction_method: ExtractionMethod?
    attr_accessor tables: Array[Table]?
    attr_accessor detected_languages: Array[String]?
    attr_accessor chunks: Array[Chunk]?
    attr_accessor images: Array[ExtractedImage]?
    attr_accessor pages: Array[PageContent]?
    attr_accessor elements: Array[Element]?
    attr_accessor djot_content: DjotContent?
    attr_accessor ocr_elements: Array[OcrElement]?
    attr_accessor document: DocumentStructure?
    attr_accessor extracted_keywords: Array[Keyword]?
    attr_accessor quality_score: Float?
    attr_accessor processing_warnings: Array[ProcessingWarning]?
    attr_accessor annotations: Array[PdfAnnotation]?
    attr_accessor children: Array[ArchiveEntry]?
    attr_accessor uris: Array[Uri]?
    attr_accessor structured_output: untyped?
    attr_accessor code_intelligence: String?
    attr_accessor llm_usage: Array[LlmUsage]?
    attr_accessor formatted_content: String?
    attr_accessor ocr_internal_document: String?

    def initialize: (content: String, mime_type: String, metadata: Metadata, ?extraction_method: ExtractionMethod, tables: Array[Table], ?detected_languages: Array[String], ?chunks: Array[Chunk], ?images: Array[ExtractedImage], ?pages: Array[PageContent], ?elements: Array[Element], ?djot_content: DjotContent, ?ocr_elements: Array[OcrElement], ?document: DocumentStructure, ?extracted_keywords: Array[Keyword], ?quality_score: Float, processing_warnings: Array[ProcessingWarning], ?annotations: Array[PdfAnnotation], ?children: Array[ArchiveEntry], ?uris: Array[Uri], ?structured_output: untyped, ?code_intelligence: String, ?llm_usage: Array[LlmUsage], ?formatted_content: String, ?ocr_internal_document: String) -> void
    def self.from_ocr: (OcrExtractionResult ocr) -> ExtractionResult
  end

  class ArchiveEntry
    # A single file extracted from an archive.
    #
    # When archives (ZIP, TAR, 7Z, GZIP) are extracted with recursive extraction
    # enabled, each processable file produces its own full `ExtractionResult`.

    attr_reader path: String
    attr_reader mime_type: String
    attr_reader result: ExtractionResult

    def initialize: (path: String, mime_type: String, result: ExtractionResult) -> void
  end

  class ProcessingWarning
    # A non-fatal warning from a processing pipeline stage.
    #
    # Captures errors from optional features that don't prevent extraction
    # but may indicate degraded results.

    attr_reader source: String
    attr_reader message: String

    def initialize: (source: String, message: String) -> void
  end

  class LlmUsage
    # Token usage and cost data for a single LLM call made during extraction.
    #
    # Populated when VLM OCR, structured extraction, or LLM-based embeddings
    # are used. Multiple entries may be present when multiple LLM calls occur
    # within one extraction (e.g. VLM OCR + structured extraction).

    attr_accessor model: String?
    attr_accessor source: String?
    attr_accessor input_tokens: Integer?
    attr_accessor output_tokens: Integer?
    attr_accessor total_tokens: Integer?
    attr_accessor estimated_cost: Float?
    attr_accessor finish_reason: String?

    def initialize: (model: String, source: String, ?input_tokens: Integer, ?output_tokens: Integer, ?total_tokens: Integer, ?estimated_cost: Float, ?finish_reason: String) -> void
  end

  class Chunk
    # A text chunk with optional embedding and metadata.
    #
    # Chunks are created when chunking is enabled in `ExtractionConfig`. Each chunk
    # contains the text content, optional embedding vector (if embedding generation
    # is configured), and metadata about its position in the document.

    attr_reader content: String
    attr_reader chunk_type: ChunkType
    attr_reader embedding: Array[Float]
    attr_reader metadata: ChunkMetadata

    def initialize: (content: String, chunk_type: ChunkType, ?embedding: Array[Float], metadata: ChunkMetadata) -> void
  end

  class HeadingContext
    # Heading context for a chunk within a Markdown document.
    #
    # Contains the heading hierarchy from document root to this chunk's section.

    attr_reader headings: Array[HeadingLevel]

    def initialize: (headings: Array[HeadingLevel]) -> void
  end

  class HeadingLevel
    # A single heading in the hierarchy.

    attr_reader level: Integer
    attr_reader text: String

    def initialize: (level: Integer, text: String) -> void
  end

  class ChunkMetadata
    # Metadata about a chunk's position in the original document.

    attr_reader byte_start: Integer
    attr_reader byte_end: Integer
    attr_reader token_count: Integer
    attr_reader chunk_index: Integer
    attr_reader total_chunks: Integer
    attr_reader first_page: Integer
    attr_reader last_page: Integer
    attr_reader heading_context: HeadingContext
    attr_reader image_indices: Array[Integer]

    def initialize: (byte_start: Integer, byte_end: Integer, ?token_count: Integer, chunk_index: Integer, total_chunks: Integer, ?first_page: Integer, ?last_page: Integer, ?heading_context: HeadingContext, image_indices: Array[Integer]) -> void
  end

  class ExtractedImage
    # Extracted image from a document.
    #
    # Contains raw image data, metadata, and optional nested OCR results.
    # Raw bytes allow cross-language compatibility - users can convert to

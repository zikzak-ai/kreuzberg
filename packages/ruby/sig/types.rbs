    # for different document types.

    attr_accessor target_dpi: Integer?
    attr_accessor auto_rotate: bool?
    attr_accessor deskew: bool?
    attr_accessor denoise: bool?
    attr_accessor contrast_enhance: bool?
    attr_accessor binarization_method: String?
    attr_accessor invert_colors: bool?

    def initialize: (target_dpi: Integer, auto_rotate: bool, deskew: bool, denoise: bool, contrast_enhance: bool, binarization_method: String, invert_colors: bool) -> void
    def self.default: () -> ImagePreprocessingConfig
  end

  class TesseractConfig
    # Tesseract OCR configuration.
    #
    # Provides fine-grained control over Tesseract OCR engine parameters.
    # Most users can use the defaults, but these settings allow optimization
    # for specific document types (invoices, handwriting, etc.).


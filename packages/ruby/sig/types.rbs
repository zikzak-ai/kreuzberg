    attr_accessor class_name: String?
    attr_accessor confidence: Float?
    attr_accessor bounding_box: BoundingBox?
    attr_accessor area_fraction: Float?

    def initialize: (?class_name: String, ?confidence: Float, ?bounding_box: BoundingBox, ?area_fraction: Float) -> void
  end


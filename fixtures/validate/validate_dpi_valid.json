	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"ocr": {
				"dpi": 300
			}
		}
	},
	"assertions": [
		{
			"type": "not_error"
		}
	]
}

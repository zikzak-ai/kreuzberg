{
	"id": "archive_zip_basic",
	"category": "archive",
	"description": "ZIP archive extraction.",
	"input": {
		"path": "archives/documents.zip",
		"media_type": "application/zip"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["application/zip", "application/x-zip-compressed"]
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		}
	]
}

{
	"id": "embedding_balanced_preset",
	"description": "Tests embedding generation with balanced preset model via chunking",
	"tags": ["embeddings", "chunking"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"chunking": {
				"max_chars": 500,
				"max_overlap": 50,
				"embedding": {
					"model": {
						"type": "preset",
						"name": "balanced"
					},
					"normalize": true
				}
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "count_min",
			"field": "chunks",
			"value": 1
		},
		{
			"type": "is_true",
			"field": "chunks_have_embeddings"
		},
		{
			"type": "is_true",
			"field": "chunks_have_content"
		}
	],
	"skip": {
		"reason": "Requires features: embeddings; Skip on platforms: x86_64-pc-windows-msvc; Embeddings not supported on Windows"
	}
}

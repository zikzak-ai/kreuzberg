{
	"id": "ocr_paddle_confidence_filter",
	"category": "ocr",
	"description": "PaddleOCR with minimum confidence threshold filtering.",
	"input": {
		"path": "images/ocr_image.jpg",
		"media_type": "image/jpeg",
		"config": {
			"ocr": {
				"backend": "paddle-ocr",
				"language": "en",
				"paddle_ocr_config": {
					"min_confidence": 80.0
				}
			},
			"force_ocr": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "image/jpeg"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 1
		}
	],
	"skip": {
		"reason": "Requires features: paddle-ocr; Tests confidence threshold filtering with PaddleOCR"
	}
}

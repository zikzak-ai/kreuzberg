{
	"id": "ocr_paddle_markdown",
	"category": "ocr",
	"description": "PaddleOCR with markdown output format.",
	"input": {
		"path": "images/test_hello_world.png",
		"media_type": "image/png",
		"config": {
			"ocr": {
				"backend": "paddle-ocr",
				"language": "en",
				"paddle_ocr_config": {
					"output_format": "markdown"
				}
			},
			"force_ocr": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "image/png"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 5
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["hello", "Hello", "world", "World"]
		}
	],
	"skip": {
		"reason": "Requires features: paddle-ocr; Tests markdown output format parity with Tesseract"
	}
}

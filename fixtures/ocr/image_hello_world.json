{
	"id": "ocr_image_hello_world",
	"category": "ocr",
	"description": "PNG image with visible English text for OCR validation.",
	"input": {
		"path": "images/test_hello_world.png",
		"media_type": "image/png",
		"config": {
			"ocr": {
				"backend": "tesseract",
				"language": "eng"
			},
			"force_ocr": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "image/png"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 5
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["hello", "world"]
		}
	],
	"skip": {
		"reason": "Requires features: tesseract; Requires Tesseract OCR for image text extraction."
	}
}

{
	"id": "ocr_paddle_image_english",
	"category": "ocr",
	"description": "Simple English image OCR with PaddleOCR backend.",
	"input": {
		"path": "images/test_hello_world.png",
		"media_type": "image/png",
		"config": {
			"ocr": {
				"backend": "paddle-ocr",
				"language": "en"
			},
			"force_ocr": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "image/png"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 5
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["hello", "Hello", "world", "World"]
		}
	],
	"skip": {
		"reason": "Requires features: paddle-ocr; Requires PaddleOCR with ONNX Runtime"
	}
}

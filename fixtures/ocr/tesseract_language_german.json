{
	"id": "ocr_tesseract_language_german",
	"category": "ocr",
	"description": "Tests Tesseract OCR with German language configuration",
	"input": {
		"path": "pdf/image_only_german_pdf.pdf",
		"media_type": "application/pdf",
		"config": {
			"ocr": {
				"backend": "tesseract",
				"language": "deu"
			},
			"force_ocr": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 20
		}
	],
	"skip": {
		"reason": "Requires features: tesseract; Requires Tesseract OCR with German language data (deu)"
	}
}

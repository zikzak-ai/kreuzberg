{
	"id": "render_output_djot",
	"category": "render",
	"description": "Extract PDF with Djot output format",
	"tags": ["render", "output_format", "djot"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"output_format": "djot"
		}
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "equals",
			"field": "output_format",
			"value": "djot"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		}
	]
}

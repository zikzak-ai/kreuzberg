{
	"id": "render_output_plain",
	"category": "render",
	"description": "Extract PDF with plain text output format",
	"tags": ["render", "output_format", "plain"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"output_format": "plain"
		}
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "equals",
			"field": "output_format",
			"value": "plain"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 50
		}
	]
}

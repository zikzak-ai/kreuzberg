{
	"id": "render_iterator",
	"category": "render",
	"description": "Iterate all PDF pages as PNG images",
	"tags": ["render", "pdf", "iterator"],
	"call": "render_page",
	"input": {
		"path": "pdf/tiny.pdf",
		"dpi": 150,
		"mode": "iterator"
	},
	"assertions": [
		{
			"type": "is_true",
			"field": "is_png"
		},
		{
			"type": "greater_than_or_equal",
			"field": "page_count",
			"value": 1
		}
	]
}

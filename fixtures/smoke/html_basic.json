{
	"id": "smoke_html_basic",
	"category": "smoke",
	"description": "Smoke test: HTML table extraction",
	"tags": ["smoke", "html"],
	"input": {
		"path": "html/simple_table.html",
		"media_type": "text/html"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "text/html"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["Sample Data Table", "Laptop", "Electronics", "Product"]
		}
	]
}

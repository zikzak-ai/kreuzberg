{
	"id": "smoke_xlsx_basic",
	"category": "smoke",
	"description": "Smoke test: XLSX with basic spreadsheet data including tables",
	"tags": ["smoke", "office", "xlsx", "tables"],
	"input": {
		"path": "xlsx/stanley_cups.xlsx",
		"media_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 100
		},
		{
			"type": "contains_all",
			"field": "content",
			"values": ["Team", "Location", "Stanley Cups", "Blues", "Flyers", "Maple Leafs", "STL", "PHI", "TOR"]
		},
		{
			"type": "count_min",
			"field": "tables",
			"value": 1
		},
		{
			"type": "greater_than_or_equal",
			"field": "metadata.sheet_count",
			"value": 2
		},
		{
			"type": "contains_all",
			"field": "metadata.sheet_names",
			"values": ["Stanley Cups"]
		}
	]
}

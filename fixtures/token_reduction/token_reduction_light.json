{
	"id": "token_reduction_light",
	"description": "Tests light token reduction mode preserves most content",
	"tags": ["token_reduction"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"token_reduction": {
				"mode": "light"
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "not_empty",
			"field": "content"
		}
	]
}

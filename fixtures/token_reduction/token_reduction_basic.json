{
	"id": "token_reduction_basic",
	"description": "Tests basic token reduction on PDF document",
	"tags": ["token_reduction"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"token_reduction": {
				"mode": "moderate"
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 5
		},
		{
			"type": "max_length",
			"field": "content",
			"value": 200
		},
		{
			"type": "not_empty",
			"field": "content"
		}
	]
}

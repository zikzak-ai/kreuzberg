{
	"id": "config_document_structure_headings",
	"description": "Tests document structure extraction with heading nodes on a DOCX",
	"tags": ["contract", "document_structure"],
	"call": "extract_file_sync",
	"input": {
		"path": "docx/unit_test_headers.docx",
		"config": {
			"include_document_structure": true
		}
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["application/vnd.openxmlformats-officedocument.wordprocessingml.document"]
		},
		{
			"type": "not_empty",
			"field": "document_structure"
		},
		{
			"type": "count_min",
			"field": "document_structure.nodes",
			"value": 1
		},
		{
			"type": "contains_all",
			"field": "document_structure.node_types",
			"values": ["heading", "paragraph"]
		}
	],
	"skip": {
		"reason": "Requires features: office"
	}
}

{
	"id": "config_tree_sitter",
	"description": "Tests tree-sitter configuration round-trip",
	"tags": ["contract", "config", "tree-sitter"],
	"call": "extract_file_sync",
	"input": {
		"path": "code/hello.py",
		"config": {
			"tree_sitter": {
				"languages": ["python", "rust"],
				"groups": ["web"],
				"process": {
					"structure": true,
					"imports": true,
					"exports": true,
					"comments": false,
					"docstrings": false,
					"symbols": false,
					"diagnostics": false
				}
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "text/x-source-code"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 5
		}
	],
	"skip": {
		"reason": "Requires features: tree-sitter"
	}
}

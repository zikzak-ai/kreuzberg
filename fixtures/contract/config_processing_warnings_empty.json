{
	"id": "config_processing_warnings_empty",
	"description": "Tests that a clean PDF extraction produces no processing warnings",
	"tags": ["contract", "config"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "is_empty",
			"field": "processing_warnings"
		}
	]
}

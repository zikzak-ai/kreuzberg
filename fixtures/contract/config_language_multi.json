{
	"id": "config_language_multi",
	"description": "Tests multi-language detection config",
	"tags": ["contract", "config", "language_detection"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"language_detection": {
				"enabled": true,
				"detect_multiple": true
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "contains_all",
			"field": "detected_languages",
			"values": ["eng"]
		}
	],
	"skip": {
		"reason": "Requires features: language-detection"
	}
}

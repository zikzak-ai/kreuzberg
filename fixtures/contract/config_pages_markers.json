{
	"id": "config_pages_markers",
	"description": "Tests page marker insertion in extracted content",
	"tags": ["contract", "config"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"pages": {
				"insert_page_markers": true
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["PAGE"]
		}
	],
	"skip": {
		"reason": "Requires features: pdf"
	}
}

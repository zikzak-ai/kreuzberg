{
	"id": "config_structured_output",
	"description": "Tests structured (JSON) output format config",
	"tags": ["contract", "config", "output_format"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"output_format": "structured"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "equals",
			"field": "output_format",
			"value": "structured"
		}
	],
	"skip": {
		"reason": "Requires features: pdf"
	}
}

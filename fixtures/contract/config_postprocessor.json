{
	"id": "config_postprocessor",
	"description": "Tests postprocessor config is accepted and extraction succeeds",
	"tags": ["contract", "config"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"postprocessor": {
				"enabled": true
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "not_empty",
			"field": "content"
		}
	]
}

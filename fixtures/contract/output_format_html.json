{
	"id": "output_format_html",
	"description": "Tests HTML output format",
	"tags": ["contract", "output_format"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"output_format": "html"
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "equals",
			"field": "output_format",
			"value": "html"
		}
	]
}

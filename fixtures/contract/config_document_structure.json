{
	"id": "config_document_structure",
	"description": "Tests include_document_structure config produces document tree",
	"tags": ["contract", "document_structure"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"include_document_structure": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "not_empty",
			"field": "document"
		},
		{
			"type": "count_min",
			"field": "document.nodes",
			"value": 1
		},
		{
			"type": "contains_all",
			"field": "document.node_types",
			"values": ["paragraph"]
		}
	]
}

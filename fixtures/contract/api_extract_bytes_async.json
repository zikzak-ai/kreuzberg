{
	"id": "api_extract_bytes_async",
	"description": "Tests async bytes extraction API (extract_bytes)",
	"tags": ["contract", "api"],
	"call": "extract_bytes",
	"input": {
		"path": "pdf/fake_memo.pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["May 5, 2023", "Mallori"]
		}
	]
}

{
	"id": "config_chunking_markdown",
	"description": "Tests markdown-aware chunker type",
	"tags": ["contract", "config", "chunking"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"chunking": {
				"chunker_type": "markdown",
				"max_chars": 500,
				"max_overlap": 50
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "count_min",
			"field": "chunks",
			"value": 1
		},
		{
			"type": "is_true",
			"field": "chunks_have_content"
		}
	],
	"skip": {
		"reason": "Requires features: chunking"
	}
}

{
	"id": "config_llm_embeddings",
	"description": "Tests VLM embeddings via liter-llm provider-hosted embedding model",
	"tags": ["contract", "config", "liter-llm", "embeddings"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"chunking": {
				"max_chars": 500,
				"max_overlap": 50,
				"embedding": {
					"model": {
						"type": "llm",
						"llm": {
							"model": "openai/text-embedding-3-small"
						}
					},
					"normalize": true
				}
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "count_min",
			"field": "chunks",
			"value": 1
		},
		{
			"type": "is_true",
			"field": "chunks_have_embeddings"
		},
		{
			"type": "is_true",
			"field": "chunks_have_content"
		}
	],
	"skip": {
		"reason": "Requires features: liter-llm; Requires liter-llm feature and KREUZBERG_LLM_API_KEY env var"
	}
}

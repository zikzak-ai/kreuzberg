{
	"id": "config_llm_structured_extraction_with_prompt",
	"description": "Tests structured extraction with custom prompt",
	"tags": ["contract", "config", "liter-llm", "structured-extraction"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"structured_extraction": {
				"schema": {
					"type": "object",
					"properties": {
						"sender": {
							"type": "string"
						},
						"recipient": {
							"type": "string"
						},
						"subject": {
							"type": "string"
						}
					},
					"required": ["sender", "recipient"]
				},
				"schema_name": "memo_parties",
				"prompt": "Extract the sender and recipient from this memo document. If not found, use 'unknown'.",
				"llm": {
					"model": "openai/gpt-4o"
				}
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "not_empty",
			"field": "structured_output"
		},
		{
			"type": "not_empty",
			"field": "structured_output.sender"
		},
		{
			"type": "not_empty",
			"field": "structured_output.recipient"
		}
	],
	"skip": {
		"reason": "Requires features: liter-llm; Requires liter-llm feature and KREUZBERG_LLM_API_KEY env var"
	}
}

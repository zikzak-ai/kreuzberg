{
	"id": "config_pdf_margins",
	"description": "Tests PDF margin exclusion configuration",
	"tags": ["contract", "config", "pdf"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"pdf_options": {
				"top_margin_fraction": 0.1,
				"bottom_margin_fraction": 0.1
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 5
		}
	],
	"skip": {
		"reason": "Requires features: pdf"
	}
}

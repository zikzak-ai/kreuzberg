{
	"id": "config_acceleration_cpu_provider",
	"category": "contract",
	"description": "Tests explicit CPU acceleration provider configuration",
	"tags": ["contract", "config", "acceleration"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"media_type": "application/pdf",
		"config": {
			"acceleration": {
				"provider": "cpu",
				"device_id": 0
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 50
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["May 5, 2023", "To Whom it May Concern"]
		}
	]
}

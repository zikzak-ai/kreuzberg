{
	"id": "config_force_ocr_pages",
	"description": "Tests that force_ocr_pages config field is accepted for selective page OCR",
	"tags": ["contract", "config", "ocr"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"force_ocr_pages": [1],
			"ocr": {
				"backend": "tesseract",
				"language": "eng"
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 1
		}
	],
	"skip": {
		"reason": "Requires features: ocr"
	}
}

{
	"id": "api_batch_file_sync",
	"description": "Tests sync batch file extraction API (batch_extract_file_sync)",
	"tags": ["contract", "api", "batch"],
	"call": "batch_extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["May 5, 2023", "Mallori"]
		}
	]
}

{
	"id": "config_images",
	"description": "Tests image extraction configuration with image assertions",
	"tags": ["contract", "config"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/embedded_images_tables.pdf",
		"config": {
			"images": {
				"extract_images": true
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "count_min",
			"field": "images",
			"value": 1
		}
	]
}

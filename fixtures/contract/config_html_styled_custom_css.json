{
	"id": "config_html_styled_custom_css",
	"description": "HTML output with inline user CSS string is embedded verbatim in the style block",
	"tags": ["contract", "output_format", "html_styled"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"output_format": "html",
			"html_output": {
				"theme": "unstyled",
				"css": ".kb-p { color: red; }",
				"embed_css": true
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "output_format",
			"value": "html"
		},
		{
			"type": "contains_all",
			"field": "content",
			"values": [".kb-p { color: red; }", "kb-doc"]
		}
	]
}

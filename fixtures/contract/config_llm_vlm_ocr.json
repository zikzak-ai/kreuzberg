{
	"id": "config_llm_vlm_ocr",
	"description": "Tests VLM OCR backend via liter-llm vision model",
	"tags": ["contract", "config", "liter-llm", "ocr"],
	"call": "extract_file_sync",
	"input": {
		"path": "images/test_hello_world.png",
		"config": {
			"ocr": {
				"backend": "vlm",
				"language": "eng",
				"vlm_config": {
					"model": "openai/gpt-4o"
				}
			}
		}
	},
	"assertions": [
		{
			"type": "not_empty",
			"field": "content"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 5
		}
	],
	"skip": {
		"reason": "Requires features: liter-llm; Requires liter-llm feature and KREUZBERG_LLM_API_KEY env var"
	}
}

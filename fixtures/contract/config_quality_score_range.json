{
	"id": "config_quality_score_range",
	"description": "Tests quality scoring produces a score with minimum bound assertion",
	"tags": ["contract", "config", "quality"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"enable_quality_processing": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "not_empty",
			"field": "quality_score"
		},
		{
			"type": "greater_than_or_equal",
			"field": "quality_score",
			"value": 0.1
		}
	],
	"skip": {
		"reason": "Requires features: quality"
	}
}

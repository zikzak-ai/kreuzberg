{
	"id": "config_chunking_tokenizer",
	"description": "Tests token-based chunk sizing with HuggingFace tokenizer",
	"tags": ["contract", "config", "chunking", "tokenizer"],
	"call": "extract_file_sync",
	"input": {
		"path": "markdown/comprehensive.md",
		"config": {
			"chunking": {
				"max_chars": 200,
				"max_overlap": 40,
				"sizing": {
					"type": "tokenizer",
					"model": "Xenova/gpt-4o"
				}
			}
		}
	},
	"assertions": [
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "count_min",
			"field": "chunks",
			"value": 2
		},
		{
			"type": "is_true",
			"field": "chunks_have_content"
		}
	],
	"skip": {
		"reason": "Requires features: chunking-tokenizers; Requires network access for HuggingFace Hub tokenizer download"
	}
}

{
	"id": "config_tables_content",
	"description": "Tests table extraction with content_contains_any assertion on DOCX with tables",
	"tags": ["contract", "config", "tables"],
	"call": "extract_file_sync",
	"input": {
		"path": "docx/docx_tables.docx"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
		},
		{
			"type": "count_min",
			"field": "tables",
			"value": 1
		}
	]
}

{
	"id": "config_language_detection_multi",
	"description": "Tests language detection with detect_multiple and min_confidence options",
	"tags": ["contract", "config", "language_detection"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"language_detection": {
				"enabled": true,
				"detect_multiple": true,
				"min_confidence": 0.3
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "contains_all",
			"field": "detected_languages",
			"values": ["eng"]
		}
	]
}

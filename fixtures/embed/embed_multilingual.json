{
	"id": "embed_multilingual",
	"description": "Standalone embedding with multilingual preset for non-English text",
	"tags": ["embed"],
	"call": "embed",
	"input": {
		"texts": ["Bonjour le monde", "Hallo Welt", "¡Hola Mundo!"],
		"config": {
			"model": {
				"type": "preset",
				"name": "multilingual"
			},
			"normalize": true
		}
	},
	"assertions": [
		{
			"type": "count_equals",
			"field": "embeddings",
			"value": 3
		},
		{
			"type": "equals",
			"field": "embedding_dimensions",
			"value": 768
		},
		{
			"type": "is_true",
			"field": "embeddings_valid"
		},
		{
			"type": "is_true",
			"field": "embeddings_finite"
		},
		{
			"type": "is_true",
			"field": "embeddings_non_zero"
		}
	],
	"skip": {
		"reason": "Requires features: embeddings; Skip on platforms: x86_64-pc-windows-msvc; Embeddings not supported on Windows MSVC"
	}
}

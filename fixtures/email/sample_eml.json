{
	"id": "email_sample_eml",
	"category": "email",
	"description": "Sample EML email file to verify email parsing.",
	"input": {
		"path": "email/sample_email.eml",
		"media_type": "message/rfc822"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "message/rfc822"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 20
		}
	]
}

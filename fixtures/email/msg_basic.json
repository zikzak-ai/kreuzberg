{
	"id": "email_msg_basic",
	"category": "email",
	"description": "Outlook MSG file extraction.",
	"input": {
		"path": "email/fake_email.msg",
		"media_type": "application/vnd.ms-outlook"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/vnd.ms-outlook"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		}
	]
}

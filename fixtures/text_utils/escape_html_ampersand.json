{
	"id": "escape_html_ampersand",
	"category": "text_utils",
	"description": "Escape ampersands in HTML text",
	"tags": ["text_utils", "html", "escaping"],
	"call": "escape_html_entities",
	"input": {
		"text": "Tom & Jerry"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "contains",
			"field": "result",
			"value": "&amp;"
		}
	]
}

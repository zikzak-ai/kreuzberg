{
	"id": "dedup_unique",
	"category": "text_utils",
	"description": "Deduplicate text with all unique lines",
	"tags": ["text_utils", "deduplication"],
	"call": "dedup_text",
	"input": {
		"text": "a\nb\nc"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "contains",
			"field": "result",
			"value": "a"
		}
	]
}

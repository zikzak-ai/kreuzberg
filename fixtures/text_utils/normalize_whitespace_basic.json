{
	"id": "normalize_whitespace_basic",
	"category": "text_utils",
	"description": "Normalize multiple spaces and newlines",
	"tags": ["text_utils", "whitespace"],
	"call": "normalize_whitespace",
	"input": {
		"text": "hello   world\n\n\nfoo"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "contains",
			"field": "result",
			"value": "hello"
		}
	]
}

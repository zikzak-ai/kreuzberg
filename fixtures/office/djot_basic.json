{
	"id": "office_djot_basic",
	"category": "office",
	"description": "Djot markup text extraction.",
	"input": {
		"path": "markdown/tables.djot",
		"media_type": "text/x-djot"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["text/x-djot", "text/djot"]
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		}
	]
}

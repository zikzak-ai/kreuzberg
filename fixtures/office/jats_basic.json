{
	"id": "office_jats_basic",
	"category": "office",
	"description": "JATS scientific article extraction.",
	"input": {
		"path": "jats/sample_article.jats",
		"media_type": "application/x-jats+xml"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["application/x-jats+xml", "text/jats"]
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		}
	]
}

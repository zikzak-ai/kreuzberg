{
	"id": "office_docbook_basic",
	"category": "office",
	"description": "DocBook XML document extraction.",
	"input": {
		"path": "docbook/docbook-reader.docbook",
		"media_type": "application/docbook+xml"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["application/docbook+xml", "text/docbook"]
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		}
	]
}

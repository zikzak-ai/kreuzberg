{
	"id": "office_keynote_basic",
	"category": "office",
	"description": "Keynote document extraction baseline.",
	"input": {
		"path": "iwork/test.key",
		"media_type": "application/x-iwork-keynote-sffkey"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/x-iwork-keynote-sffkey"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 5
		}
	]
}

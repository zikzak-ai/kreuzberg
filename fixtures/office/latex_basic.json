{
	"id": "office_latex_basic",
	"category": "office",
	"description": "LaTeX document text extraction.",
	"input": {
		"path": "latex/basic_sections.tex",
		"media_type": "application/x-latex"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["application/x-latex", "text/x-latex"]
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 20
		}
	]
}

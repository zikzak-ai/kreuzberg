{
	"id": "office_mdx_getting_started",
	"category": "office",
	"description": "Real-world MDX extraction from mdx-js/mdx getting-started.mdx with imports, exports, JSX components, code blocks, and reference links.",
	"input": {
		"path": "markdown/mdx_getting_started.mdx",
		"media_type": "text/mdx"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["text/mdx", "text/x-mdx"]
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 2000
		},
		{
			"type": "contains_all",
			"field": "content",
			"values": [
				"Getting started",
				"Prerequisites",
				"Quick start",
				"Bundler",
				"Security",
				"Integrations",
				"esbuild",
				"Rollup",
				"webpack",
				"React"
			]
		},
		{
			"type": "not_contains",
			"field": "content",
			"values": ["import {Note}"]
		},
		{
			"type": "not_contains",
			"field": "content",
			"values": ["export const info"]
		},
		{
			"type": "not_contains",
			"field": "content",
			"values": ["export const navSortSelf"]
		}
	],
	"skip": {
		"reason": "Requires features: mdx"
	}
}

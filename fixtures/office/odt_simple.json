{
	"id": "office_odt_simple",
	"category": "office",
	"description": "Basic ODT document with paragraphs and headings.",
	"input": {
		"path": "odt/simple.odt",
		"media_type": "application/vnd.oasis.opendocument.text"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/vnd.oasis.opendocument.text"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 50
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["favorite things", "Parrots", "Analysis"]
		}
	]
}

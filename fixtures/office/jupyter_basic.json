{
	"id": "office_jupyter_basic",
	"category": "office",
	"description": "Jupyter notebook extraction.",
	"input": {
		"path": "jupyter/rank.ipynb",
		"media_type": "application/x-ipynb+json"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/x-ipynb+json"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		}
	]
}

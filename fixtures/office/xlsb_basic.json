{
	"id": "office_xlsb_basic",
	"category": "office",
	"description": "Excel binary workbook (.xlsb) extraction.",
	"input": {
		"path": "xlsx/test_xlsb.xlsb",
		"media_type": "application/vnd.ms-excel.sheet.binary.macroEnabled.12"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": [
				"application/vnd.ms-excel.sheet.binary.macroEnabled.12",
				"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
			]
		},
		{
			"type": "not_empty",
			"field": "content"
		}
	]
}

{
	"id": "office_xls_legacy",
	"category": "office",
	"description": "Legacy XLS spreadsheet to ensure backward compatibility.",
	"input": {
		"path": "xls/test_excel.xls",
		"media_type": "application/vnd.ms-excel"
	},
	"assertions": [
		{
			"type": "equals",

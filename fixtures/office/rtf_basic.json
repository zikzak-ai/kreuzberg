{
	"id": "office_rtf_basic",
	"category": "office",
	"description": "RTF document text extraction.",
	"input": {
		"path": "rtf/extraction_test.rtf",
		"media_type": "application/rtf"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["application/rtf", "text/rtf"]
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		}
	]
}

{
	"id": "office_pptm_basic",
	"category": "office",
	"description": "PowerPoint macro-enabled presentation (.pptm) extraction.",
	"input": {
		"path": "pptx/powerpoint_with_image.pptm",
		"media_type": "application/vnd.ms-powerpoint.presentation.macroEnabled.12"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": [
				"application/vnd.ms-powerpoint.presentation.macroEnabled.12",
				"application/vnd.openxmlformats-officedocument.presentationml.presentation"
			]
		},
		{
			"type": "not_empty",
			"field": "content"
		}
	]
}

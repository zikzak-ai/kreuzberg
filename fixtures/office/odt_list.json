{
	"id": "office_odt_list",
	"category": "office",
	"description": "ODT document containing unordered lists with nesting.",
	"input": {
		"path": "odt/unorderedList.odt",
		"media_type": "application/vnd.oasis.opendocument.text"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/vnd.oasis.opendocument.text"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 30
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["list item", "New level", "Pushed us"]
		}
	]
}

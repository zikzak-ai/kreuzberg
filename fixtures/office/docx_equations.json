{
	"id": "office_docx_equations",
	"category": "office",
	"description": "DOCX file containing equations to validate math extraction.",
	"input": {
		"path": "docx/equations.docx",
		"media_type": "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 20
		}
	]
}

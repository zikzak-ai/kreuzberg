{
	"id": "office_commonmark_basic",
	"category": "office",
	"description": "CommonMark (.commonmark) text extraction.",
	"input": {
		"path": "markdown/sample.commonmark",
		"media_type": "text/markdown"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["text/markdown", "text/plain", "text/x-commonmark"]
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 5
		}
	]
}

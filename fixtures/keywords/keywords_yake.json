{
	"id": "keywords_yake",
	"description": "Tests keyword extraction using YAKE algorithm",
	"tags": ["keywords", "yake"],
	"call": "extract_file_sync",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"config": {
			"keywords": {
				"algorithm": "yake",
				"max_keywords": 10
			}
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "not_empty",
			"field": "keywords"
		},
		{
			"type": "count_min",
			"field": "keywords",
			"value": 1
		},
		{
			"type": "less_than_or_equal",
			"field": "keywords_count",
			"value": 10
		}
	],
	"skip": {
		"reason": "Requires features: keywords-yake"
	}
}

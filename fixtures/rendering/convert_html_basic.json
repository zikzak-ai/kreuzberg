{
	"id": "convert_html_basic",
	"category": "rendering",
	"description": "Convert basic HTML to Markdown format",
	"tags": ["html_to_markdown", "conversion", "basic"],
	"call": "convert_html_to_markdown",
	"input": {
		"html": "<h1>Title</h1><p>Paragraph text.</p><ul><li>Item 1</li><li>Item 2</li></ul>"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "contains",
			"field": "content",
			"value": "Title"
		}
	]
}

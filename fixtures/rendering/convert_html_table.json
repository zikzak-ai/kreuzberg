	"input": {
		"html": "<table><tr><th>Column A</th><th>Column B</th></tr><tr><td>1</td><td>2</td></tr><tr><td>3</td><td>4</td></tr></table>"
	},
	"assertions": [
		{
			"type": "not_error"

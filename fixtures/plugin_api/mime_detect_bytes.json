{
	"id": "mime_detect_bytes",
	"category": "mime_utilities",
	"description": "Detect MIME type from file bytes",
	"tags": ["mime", "detection", "bytes"],
	"call": "detect_mime_type",
	"input": {
		"setup": {
			"test_data": "%PDF-1.4\\n"
		},
		"args": ["${test_data_bytes}"]
	},
	"assertions": [
		{
			"type": "contains",
			"field": "result",
			"value": "pdf"
		}
	]
}

{
	"id": "mime_get_extensions",
	"category": "mime_utilities",
	"description": "Get file extensions for a MIME type",
	"tags": ["mime", "extensions", "lookup"],
	"call": "get_extensions_for_mime",
	"input": {
		"args": ["application/pdf"]
	},
	"assertions": [
		{
			"type": "contains",
			"field": "result",
			"value": "pdf"
		}
	]
}

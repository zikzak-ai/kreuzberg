{
  "id": "ocr_backends_unregister",
  "category": "ocr_backend_management",
  "description": "Unregister nonexistent OCR backend gracefully",
  "tags": [
    "ocr",
    "plugin_management",
    "unregister",
    "trait-bridge"
  ],
  "call": "unregister_ocr_backend",
  "input": {
    "name": "nonexistent-backend-xyz"
  },
  "assertions": [
    {
      "type": "not_error"
    }
  ],
  "skip": {
    "languages": ["python", "rust", "node", "go", "ruby", "elixir", "wasm", "java", "csharp", "php", "r", "dart", "kotlin_android", "swift", "zig"],
    "reason": "register/unregister APIs require a host-language Arc<dyn Trait> backend object; the JSON e2e harness cannot synthesize it. Trait-bridge round-trips are exercised in each language native test suite."
  }
}

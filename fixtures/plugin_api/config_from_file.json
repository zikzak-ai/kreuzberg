{
	"id": "config_from_file",
	"category": "configuration",
	"description": "Load configuration from a TOML file",
	"tags": ["configuration", "toml", "file_loading"],
	"call": "from_file",
	"input": {
		"setup": {
			"create_temp_file": true,
			"temp_file_name": "test_config.toml",
			"temp_file_content": "[chunking]\nmax_chars = 100\nmax_overlap = 20\n\n[language_detection]\nenabled = false\n"
		},
		"args": ["${temp_file_path}"],
		"is_method": true,
		"class_name": "ExtractionConfig"
	},
	"assertions": [
		{
			"type": "not_empty",
			"field": "result.chunking"
		},
		{
			"type": "equals",
			"field": "result.chunking.max_chars",
			"value": 100
		},
		{
			"type": "equals",
			"field": "result.chunking.max_overlap",
			"value": 20
		},
		{
			"type": "not_empty",
			"field": "result.language_detection"
		},
		{
			"type": "equals",
			"field": "result.language_detection.enabled",
			"value": false
		}
	]
}

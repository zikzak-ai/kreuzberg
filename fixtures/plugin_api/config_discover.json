{
	"id": "config_discover",
	"category": "configuration",
	"description": "Discover configuration from current or parent directories",
	"tags": ["configuration", "toml", "discovery"],
	"call": "discover",
	"input": {
		"setup": {
			"create_temp_dir": true,
			"create_temp_file": true,
			"temp_file_name": "kreuzberg.toml",
			"temp_file_content": "[chunking]\nmax_chars = 50\n",
			"create_subdirectory": true,
			"subdirectory_name": "subdir",
			"change_directory": true
		},
		"is_method": true,
		"class_name": "ExtractionConfig",
		"teardown": {
			"restore_directory": true
		}
	},
	"assertions": [
		{
			"type": "not_empty",
			"field": "result.chunking"
		},
		{
			"type": "equals",
			"field": "result.chunking.max_chars",
			"value": 50
		}
	]
}

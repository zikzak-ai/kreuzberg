{
	"id": "mime_detect_path",
	"category": "mime_utilities",
	"description": "Detect MIME type from file path",
	"tags": ["mime", "detection", "path"],
	"call": "detect_mime_type_from_path",
	"input": {
		"setup": {
			"create_temp_file": true,
			"temp_file_name": "test.txt",
			"temp_file_content": "Hello, world!"
		},
		"args": ["${temp_file_path}"]
	},
	"assertions": [
		{
			"type": "contains",
			"field": "result",
			"value": "text"
		}
	]
}

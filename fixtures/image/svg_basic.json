{
	"id": "image_svg_basic",
	"category": "image",
	"description": "SVG image extraction.",
	"input": {
		"path": "xml/simple_svg.svg",
		"media_type": "image/svg+xml"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "image/svg+xml"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 5
		}
	]
}

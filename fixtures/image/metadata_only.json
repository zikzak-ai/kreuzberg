{
	"id": "image_metadata_only",
	"category": "image",
	"description": "JPEG image to validate metadata extraction without OCR.",
	"input": {
		"path": "images/example.jpg",
		"media_type": "image/jpeg",
		"config": {
			"ocr": null,
			"disable_ocr": true
		}
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "image/jpeg"
		},
		{
			"type": "max_length",
			"field": "content",
			"value": 200
		}
	]
}

{
	"id": "image_pbm_basic",
	"category": "image",
	"description": "PBM (portable bitmap) image extraction via OCR.",
	"input": {
		"path": "images_extra/ocr_image.pbm",
		"media_type": "image/x-portable-bitmap"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["image/x-portable-bitmap", "image/x-pbm"]
		},
		{
			"type": "not_empty",
			"field": "content"
		}
	],
	"skip": {
		"reason": "Requires features: tesseract"
	}
}

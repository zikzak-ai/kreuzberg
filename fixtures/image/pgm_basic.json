{
	"id": "image_pgm_basic",
	"category": "image",
	"description": "PGM (portable graymap) image extraction via OCR.",
	"input": {
		"path": "images_extra/ocr_image.pgm",
		"media_type": "image/x-portable-graymap"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["image/x-portable-graymap", "image/x-pgm"]
		},
		{
			"type": "not_empty",
			"field": "content"
		}
	],
	"skip": {
		"reason": "Requires features: tesseract"
	}
}

{
	"id": "image_ppm_basic",
	"category": "image",
	"description": "PPM (portable pixmap) image extraction via OCR.",
	"input": {
		"path": "images_extra/ocr_image.ppm",
		"media_type": "image/x-portable-pixmap"
	},
	"assertions": [

{
	"id": "extract_pdf_code",
	"category": "extraction",
	"description": "Extract text from PDF containing code snippets and formulas",
	"tags": ["pdf", "code", "formula"],
	"call": "extract_text_from_pdf",
	"input": {
		"data": "pdf/code_and_formula.pdf"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 20
		}
	]
}

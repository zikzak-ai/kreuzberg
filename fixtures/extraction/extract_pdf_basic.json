{
	"id": "extract_pdf_basic",
	"category": "extraction",
	"description": "Extract text from a basic PDF document containing memo content",
	"tags": ["pdf", "text_extraction", "basic"],
	"call": "extract_text_from_pdf",
	"input": {
		"data": "pdf/fake_memo.pdf"
	},
	"assertions": [
		{
			"type": "not_error"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 50
		}
	]
}

{
	"id": "structured_tsv_basic",
	"category": "structured",
	"description": "TSV (tab-separated values) data file extraction.",
	"input": {
		"path": "data_formats/employees.tsv",
		"media_type": "text/tab-separated-values"
	},
	"assertions": [
		{
			"type": "contains_any",
			"field": "mime_type",
			"values": ["text/tab-separated-values", "text/plain"]
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		}
	]
}

{
	"id": "pdf_simple_text",
	"category": "pdf",
	"description": "Simple text-heavy PDF should extract content without OCR or tables.",
	"input": {
		"path": "pdf/fake_memo.pdf",
		"media_type": "application/pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 50
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["May 5, 2023", "To Whom it May Concern", "Mallori"]
		}
	]
}

{
	"id": "pdf_tables_large",
	"category": "pdf",
	"description": "Large PDF with extensive tables to stress table extraction.",
	"input": {
		"path": "pdf/large.pdf",
		"media_type": "application/pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 500
		}
	]
}

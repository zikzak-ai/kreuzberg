{
  "id": "render_pdf_page_first",
  "category": "pdf",
  "description": "render_pdf_page_to_png: first page",
  "call": "render_pdf_page_to_png",
  "input": {
    "pdf_path": "pdf/fake_memo.pdf",
    "page_number": 0
  },
  "assertions": [

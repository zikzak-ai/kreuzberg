{
	"id": "pdf_password_protected",
	"category": "pdf",
	"description": "Copy-protected PDF should extract content (pdfium handles copy-protection transparently).",
	"input": {
		"path": "pdf/copy_protected.pdf",
		"media_type": "application/pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 50
		},
		{
			"type": "contains_any",
			"field": "content",
			"values": ["LayoutParser", "document image analysis", "deep learning"]
		}
	],
	"skip": {
		"reason": "Skip if document missing"
	}
}

{
	"id": "code_shebang_detection",
	"category": "code",
	"description": "Test language detection from shebang line via bytes input",
	"tags": ["code", "shebang", "tree-sitter"],
	"call": "extract_bytes_sync",
	"input": {
		"path": "code/script.sh",
		"media_type": "text/x-source-code"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "text/x-source-code"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "contains_all",
			"field": "content",
			"values": ["build", "clean"]
		}
	],
	"skip": {
		"reason": "Requires features: tree-sitter"
	}
}

{
	"id": "code_python_basic",
	"category": "code",
	"description": "Smoke test: Python source code file extraction",
	"tags": ["code", "python", "tree-sitter"],
	"input": {
		"path": "code/hello.py",
		"media_type": "text/x-source-code"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "text/x-source-code"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "contains_all",
			"field": "content",
			"values": ["def greet", "class Greeter", "import os"]
		}
	],
	"skip": {
		"reason": "Requires features: tree-sitter"
	}
}

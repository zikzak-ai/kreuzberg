{
	"id": "code_rust_basic",
	"category": "code",
	"description": "Smoke test: Rust source code file extraction",
	"tags": ["code", "rust", "tree-sitter"],
	"input": {
		"path": "code/main.rs",
		"media_type": "text/x-source-code"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "text/x-source-code"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 10
		},
		{
			"type": "contains_all",
			"field": "content",
			"values": ["struct Store", "fn main", "HashMap"]
		}
	],
	"skip": {
		"reason": "Requires features: tree-sitter"
	}
}

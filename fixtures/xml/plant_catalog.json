{
	"id": "xml_plant_catalog",
	"category": "xml",
	"description": "XML plant catalog to validate streaming XML extraction.",
	"input": {
		"path": "xml/plant_catalog.xml",
		"media_type": "application/xml"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "mime_type",
			"value": "application/xml"
		},
		{
			"type": "min_length",
			"field": "content",
			"value": 100
		}
	]
}

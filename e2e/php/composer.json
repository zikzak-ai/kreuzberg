{
  "name": "kreuzberg-dev/e2e-php",
  "description": "E2e tests for PHP bindings",
  "type": "project",
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "guzzlehttp/guzzle": "^7.0"
  },
  "autoload": {
